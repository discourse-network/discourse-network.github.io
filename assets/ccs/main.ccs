/* Add styles for the navigation bar */
nav {
  background-color: #333;
  padding: 10px 0;
}

nav a {
  color: white;
  padding: 10px 15px;
  text-decoration: none;
  display: inline-block;
}

nav a:hover {
  background-color: #555;
}

/* Center the links horizontally */
header nav {
  text-align: center;
}

header nav a {
  margin: 0 10px;
}
